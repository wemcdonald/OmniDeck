# OmniDeck - Secrets Example
#
# Copy this file to secrets.yaml and fill in real values.
# secrets.yaml is gitignored — NEVER commit real tokens to version control.
#
# Values here are referenced from main.yaml using !secret <key_name>
# (identical to Home Assistant's secrets pattern).

# ─── Home Assistant ───────────────────────────────────────────────────────────
# WebSocket URL — use ws:// for local, wss:// for remote/HTTPS instances.
ha_url: "ws://homeassistant.local:8123/api/websocket"

# Long-lived access token — generate in HA: Profile → Long-Lived Access Tokens
ha_token: "your-ha-long-lived-access-token-here"

# ─── Spotify ──────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Redirect URI must be set to: http://localhost:8888/callback
spotify_client_id: "your-spotify-client-id-here"
spotify_client_secret: "your-spotify-client-secret-here"

# Obtain via the OAuth flow (run: omnideck spotify-auth)
spotify_refresh_token: "your-spotify-refresh-token-here"

# ─── Discord ──────────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
# Required intents: Server Members, Message Content, Presence
discord_bot_token: "your-discord-bot-token-here"

# Right-click server → Copy Server ID (Developer Mode must be enabled)
discord_guild_id: "your-discord-server-id-here"

# Right-click voice channel → Copy Channel ID
discord_voice_channel_id: "your-discord-voice-channel-id-here"

# ─── Slack ────────────────────────────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
# Required scopes: dnd:read, dnd:write, users:read, channels:read
# Install to workspace and copy the User OAuth Token (xoxp-...)
slack_user_token: "xoxp-your-slack-user-token-here"

# ─── Hub Security ────────────────────────────────────────────────────────────
# Optional: password-protect the web UI.
# Generate with: echo "mypassword" | npx tsx hub/scripts/hash-password.ts
# hub_password_hash: "$2a$10$..."
