{
  "name": "omnideck-hub",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:web": "cd web && pnpm dev",
    "build": "tsup src/index.ts --format esm",
    "build:web": "cd web && pnpm install && pnpm build",
    "build:all": "pnpm build:web && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@elgato-stream-deck/node": "^7.6.0",
    "@hono/node-server": "^1.19.11",
    "@iconify-json/material-symbols": "^1.2.63",
    "@iconify/utils": "^3.1.0",
    "@napi-rs/canvas": "^0.1.97",
    "@omnideck/plugin-schema": "workspace:*",
    "@peculiar/x509": "^1.14.3",
    "bcryptjs": "^3.0.3",
    "bonjour-service": "^1.3.0",
    "chokidar": "^5.0.0",
    "esbuild": "^0.27.4",
    "hono": "^4.12.8",
    "pino": "^10.3.1",
    "sharp": "^0.34.5",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
